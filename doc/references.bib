@article{Foster2026,
  title = {Global Warming Has Accelerated Significantly},
  abstract = {"Abstract Recent record‐hot years have caused discussion over whether global warming has accelerated. Previous analysis found acceleration (i.e., increase in warming rate) has not yet reached a 95\% confidence level, given natural temperature variability. We remove the estimated influence of three main natural variability factors: El Ni{\~n}o, volcanism, and solar variation. The resulting adjusted and thus less ``noisy'' data show that there has been acceleration with over 98\% confidence, with faster warming over the last 10+ years than during any previous decade."},
  volume = {53},
  ISSN = {1944-8007},
  url = {http://dx.doi.org/10.1029/2025GL118804},
  DOI = {10.1029/2025gl118804},
  number = {5},
  journal = {Geophysical Research Letters},
  publisher = {American Geophysical Union (AGU)},
  author = {Foster, G. and Rahmstorf, S.},
  year = {2026},
  month = {Mar},
  language  = "en",
}

