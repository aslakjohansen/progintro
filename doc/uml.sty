\NeedsTeXFormat{LaTeX2e}[1995/12/01]
\ProvidesPackage{uml}[2026/02/16 v0.1
                 LaTeX package for UML diagrams]

% packages and TikZ libraries
\usetikzlibrary{arrows}

% example of how to hide inner definitions
\newcommand{\@notexported}[0]{test}
\newcommand{\exported}[0]{\@notexported}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% styling

% properties
\newcommand{\@headerHeight}[0]{8mm}
\newcommand{\@subHeaderHeight}[0]{4mm}
\newcommand{\@fieldHeight}[0]{5mm}
\newcommand{\@border}[0]{1mm}

\tikzstyle{node}=[
  overlay,
  rectangle,
  draw=purple,
  thick,
  minimum width=20mm,
]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% generic producers

% args:
% - 1: id modifier (default: empty)
% - 2: name
% - 3: index
% - 4: field name,
% - 5: field type
% - 6: visibility modifier
% - 7: header height
\newcommand{\@visibleField}[7]{
  \node[minimum height=\@fieldHeight,anchor=north west]
    (#2 #4 #1)
    at ([yshift=-#7-1*\@border-#3*\@fieldHeight,xshift=\@border]#2.north west)
    {\texttt{#6 #4 : #5}}
  ;
}

% args:
% - 1: id modifier (default: empty)
% - 2: name
% - 3: field count
% - 4: index
% - 5: return type
% - 6: method name,
% - 7: parameter list
% - 8: visibility modifier
% - 9: header height
\newcommand{\@visibleMethod}[9]{
  \node[minimum height=\@fieldHeight,anchor=north west]
    (#2 #6 #1)
    at ([yshift=-#9-3*\@border-#3*\@fieldHeight-#4*\@fieldHeight,xshift=\@border]#2.north west)
    {\texttt{#8 #6 (#7) : #5}}
  ;
}

% args:
% - 1: extra params to tikz node (just keep empty)
% - 2: base id
% - 3: position
% - 4: header height
% - 5: field height
% - 6: method height
\newcommand{\@genericElement}[6]{
  \node[
    node,
    #1,
    minimum height=#4+#5+#6,
  ] (#2) at (#3) {};
  
  \draw[thick] ([yshift=-#4]#2.north west)
             --([yshift=-#4]#2.north east);
  \draw[thick] ([yshift=-#4-#5]#2.north west)
             --([yshift=-#4-#5]#2.north east);
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% relations

\tikzstyle{inherit} = [thick,->,>=open triangle 45, draw=teal]
\tikzstyle{instanceof} = [thick, densely dotted, draw=purple]
\tikzstyle{implements} = [inherit, densely dashed, draw=orange]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% specific environments

% args:
% - 1: class name
% - 2: extra params to tikz node (just keep empty)
% - 3: position
% - 4: number of attributes
% - 5: number of methods
\newenvironment{umlclass}[5]
{
  % args:
  % - 1: id modifier (default: empty)
  % - 2: index
  % - 3: field name,
  % - 4: field type
  \newcommand{\publicField}[4][]{
    \@visibleField{##1}{class#1}{##2}{##3}{##4}{+}{\@headerHeight}
  }
  \newcommand{\protectedField}[4][]{
    \@visibleField{##1}{class#1}{##2}{##3}{##4}{\%}{\@headerHeight}
  }
  \newcommand{\privateField}[4][]{
    \@visibleField{##1}{class#1}{##2}{##3}{##4}{-}{\@headerHeight}
  }
  
  % args:
  % - 1: id modifier (default: empty)
  % - 2: index
  % - 3: return type
  % - 4: method name
  % - 5: parameter list
  \newcommand{\publicMethod}[5][]{
    \@visibleMethod{##1}{class#1}{#4}{##2}{##3}{##4}{##5}{+}{\@headerHeight}
  }
  \newcommand{\protectedMethod}[5][]{
    \@visibleMethod{##1}{class#1}{#4}{##2}{##3}{##4}{##5}{\%}{\@headerHeight}
  }
  \newcommand{\privateMethod}[5][]{
    \@visibleMethod{##1}{class#1}{#4}{##2}{##3}{##4}{##5}{-}{\@headerHeight}
  }
  
  \@genericElement{#2}{class#1}{#3}{\@headerHeight}{(2*\@border+#4*\@fieldHeight)}{(2*\@border+#5*\@fieldHeight)}
  
  \node[anchor=center,text=black] (class#1name) at ([yshift=-\@headerHeight/2]class#1.north) {\large{#1}};
}
{
}

% args:
% - 1: class name
% - 2: extra params to tikz node (just keep empty)
% - 3: position
% - 4: number of attributes
% - 5: number of methods
\newenvironment{umlaclass}[5]
{
  % args:
  % - 1: id modifier (default: empty)
  % - 2: index
  % - 3: field name,
  % - 4: field type
  \newcommand{\publicField}[4][]{
    \@visibleField{##1}{aclass#1}{##2}{##3}{##4}{+}{(\@headerHeight*2/3+\@subHeaderHeight)}
  }
  \newcommand{\protectedField}[4][]{
    \@visibleField{##1}{aclass#1}{##2}{##3}{##4}{\%}{(\@headerHeight*2/3+\@subHeaderHeight)}
  }
  \newcommand{\privateField}[4][]{
    \@visibleField{##1}{aclass#1}{##2}{##3}{##4}{-}{(\@headerHeight*2/3+\@subHeaderHeight)}
  }
  
  % args:
  % - 1: id modifier (default: empty)
  % - 2: index
  % - 3: return type
  % - 4: method name
  % - 5: parameter list
  \newcommand{\publicMethod}[5][]{
    \@visibleMethod{##1}{aclass#1}{#4}{##2}{##3}{##4}{##5}{+}{(\@headerHeight*2/3+\@subHeaderHeight)}
  }
  \newcommand{\protectedMethod}[5][]{
    \@visibleMethod{##1}{aclass#1}{#4}{##2}{##3}{##4}{##5}{\%}{(\@headerHeight*2/3+\@subHeaderHeight)}
  }
  \newcommand{\privateMethod}[5][]{
    \@visibleMethod{##1}{aclass#1}{#4}{##2}{##3}{##4}{##5}{-}{(\@headerHeight*2/3+\@subHeaderHeight)}
  }
  
  \@genericElement{#2}{aclass#1}{#3}{(\@headerHeight*2/3+\@subHeaderHeight)}{(2*\@border+#4*\@fieldHeight)}{(2*\@border+#5*\@fieldHeight)}
  
  \node[anchor=center,text=black] (aclass#1name) at ([yshift=-\@subHeaderHeight/2-0.5mm]aclass#1.north) {\small{\texttt{<<abstract>>}}};
  \node[anchor=center,text=black] (aclass#1name) at ([yshift=-\@subHeaderHeight*2/3-\@headerHeight/2+0.5mm]aclass#1.north) {\large{#1}};
}
{
}

